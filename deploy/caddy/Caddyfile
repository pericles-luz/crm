# Caddy 2 config — Fase 0 (SIN-62208).
# Wildcard internal vhost *.crm.local + reverse_proxy to app:8080.
# Per-tenant routing refinements arrive in PR5.
#
# Security headers (HSTS / Permissions-Policy / COOP / COEP / CORP / X-Frame /
# X-Content-Type / Referrer-Policy / Server + X-Powered-By stripping) live in
# security-headers.caddy and are imported into every site block — see ADR 0082
# §1 (SIN-62229) and SIN-62283 (PR-B1). CSP is NOT here; it lands in PR-B3 once
# the Go backend mints a per-request nonce (SIN-62245).
{
	# Local-only stack: disable automatic public ACME until staging.
	auto_https off
	admin off

	# ADR 0079 §2 (SIN-62242). All recursive DNS queries Caddy makes
	# from within a Caddyfile site — DNS-01 challenge resolution today
	# (the future `0079a-acme-dns01` plugin), and any other site-level
	# DNS lookup — are pinned to the Unbound sidecar. Unbound REFUSES
	# to return a private/loopback/link-local address, so an attacker
	# who publishes evil.test → 127.0.0.1 cannot make Caddy issue a
	# certificate against that response.
	#
	# Caddy's HTTP-01 challenge target is resolved via the container's
	# /etc/resolv.conf; in deploy/compose/compose.yml the caddy service
	# sets `dns: ["unbound"]` so the OS resolver is also Unbound. That
	# closes the second leg of the F44 attack surface.
	acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

(secure-resolvers) {
	tls {
		resolvers unbound:5353
	}
}

# Plain HTTP passthrough for local smoke checks (curl http://localhost:8080/health).
:8080 {
	import security-headers.caddy
	reverse_proxy app:8080
}

# Wildcard tenant vhost. TLS is auto-managed in stg/prod (PR9 wires the issuer).
*.crm.local, crm.local {
	import security-headers.caddy
	import secure-resolvers
	reverse_proxy app:8080

	encode zstd gzip
}

# SIN-62243 F45 — global on_demand_tls policy. Caddy consults the app's
# internal listener at app:8081/internal/tls/ask before issuing a cert
# for any custom domain (any host that does not match a literal site
# block above). The internal listener is unpublished — only the docker
# bridge network can reach :8081 — so a request for /internal/tls/ask
# arriving at this Caddy from the public internet hits a literal site
# block and never reaches the ask handler.
{
	on_demand_tls {
		ask http://app:8081/internal/tls/ask
		# Modest per-host issuance burst so a single domain cannot
		# exhaust Let's Encrypt's per-account quota; the app's own
		# Redis-backed sliding window is the primary limit (3/min).
		burst 3
	}
}

# Custom-domain catch-all: any host the SNI client presents that is NOT
# in the literal site blocks above lands here. Caddy consults
# on_demand_tls.ask above; only verified, non-paused hosts are allowed
# through to the app. tls { on_demand } MUST be paired with the global
# on_demand_tls policy or Caddy will refuse to issue.
:443 {
	tls {
		on_demand
	}
	import security-headers.caddy
	reverse_proxy app:8080
	encode zstd gzip
}
