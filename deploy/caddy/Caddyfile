# Caddy 2 config — Fase 0 (SIN-62208).
# Wildcard internal vhost *.crm.local + reverse_proxy to app:8080.
# Per-tenant routing refinements arrive in PR5.
#
# Security headers (HSTS / Permissions-Policy / COOP / COEP / CORP / X-Frame /
# X-Content-Type / Referrer-Policy / Server + X-Powered-By stripping) live in
# security-headers.caddy and are imported into every site block — see ADR 0082
# §1 (SIN-62229) and SIN-62283 (PR-B1). CSP is NOT here; it lands in PR-B3 once
# the Go backend mints a per-request nonce (SIN-62245).
{
	# Local-only stack: disable automatic public ACME until staging.
	auto_https off
	admin off
}

# Plain HTTP passthrough for local smoke checks (curl http://localhost:8080/health).
:8080 {
	import security-headers.caddy
	reverse_proxy app:8080
}

# Wildcard tenant vhost. TLS is auto-managed in stg/prod (PR9 wires the issuer).
*.crm.local, crm.local {
	import security-headers.caddy
	reverse_proxy app:8080

	encode zstd gzip
}
