# Copy to deploy/compose/.env and fill in real values for local dev.
# Never commit .env. Same shape (filled by sops/secret manager) feeds stg in PR9.

# Postgres
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me

# Optional: explicit DSN for the app pool (SIN-62212). When unset, compose
# composes one from POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB. Override
# this in stg/prod to point at the app_runtime role (NOBYPASSRLS) — see
# docs/adr/0071-postgres-roles.md.
# DATABASE_URL=postgres://app_runtime:change-me@postgres:5432/crm?sslmode=disable

# DB_ENFORCE_RLS_ROLE (SIN-65590) — defense-in-depth boot guard. When "1",
# the app refuses to boot if the runtime DB role is SUPERUSER or BYPASSRLS,
# because RLS (the DB half of tenant isolation, with WithTenant the app half)
# is then silently OFF and tenants can see each other's rows (SIN-65580). The
# guard ALWAYS logs a structured WARNING when the role bypasses RLS; the flag
# turns that warning into a hard boot failure. compose.stg.yml and compose.yml
# default it to "1" — pair it with a DATABASE_URL that points at app_runtime
# (NOBYPASSRLS) above. LEAVE IT UNSET for local `make up`, which intentionally
# connects as the bootstrap superuser `crm`; then you only get the WARNING.
# The guard reads ONLY current_user / pg_roles — never the DSN or credentials.
# DB_ENFORCE_RLS_ROLE=1

# MinIO
MINIO_ROOT_USER=crm-admin
MINIO_ROOT_PASSWORD=change-me-too

# SIN-63195 — encrypted-backup sidecar AWS credentials.
#   In local dev these point at the local MinIO instance (same values as
#   MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above). The reason this is read
#   from env_file (NOT compose.yml `environment:`) is that `environment:`
#   values are visible via `docker inspect`. SecurityEngineer review on
#   SIN-63195 (2026-05-21) flagged this as MEDIUM — keep AWS_* here.
AWS_ACCESS_KEY_ID=crm-admin
AWS_SECRET_ACCESS_KEY=change-me-too
AWS_DEFAULT_REGION=us-east-1

# Caddy security headers (SIN-62283 / ADR 0082 §1; Fase 6 hardening
# [SIN-63218](/SIN/issues/SIN-63218)).
#
# Default is the HSTS preload-list minimum (1 year). Override to a smaller
# value only during a brand-new host's TLS soak, then bump back up — leaving
# it at 300 re-opens the MitM TLS downgrade window the pen-test flagged.
HSTS_MAX_AGE=31536000

# Transactional email (SIN-62321 / ADR 0096).
#   Provider selection. Allowed values:
#     mailgun   — production (requires MAILGUN_* below)
#     recorder  — CI / integration tests (in-memory capture)
#     noop      — dev default; messages are validated and dropped
#   When APP_ENV=production, EMAIL_PROVIDER MUST be set or boot fails.
# EMAIL_PROVIDER=noop
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_REGION=us           # or: eu

# Wallet-balance Slack alerts (SIN-62912 / Fase 3 W3D).
#   When set, the wallet-alerter-worker POSTs a `:warning: Wallet zerada ...`
#   message to this incoming-webhook URL every time a tenant runs out of
#   tokens (subject `wallet.balance.depleted`). When empty, the worker
#   still boots and consumes events but skips the POST and logs a one-shot
#   WARN at startup (degraded mode — AC #3 of SIN-62905). Operators MUST
#   resolve the webhook out-of-band; never paste it into argv or YAML.
# SLACK_ALERTS_WEBHOOK_URL=

# Operator-console hostname (SIN-65076 / ADR 0073 §D1).
#   When set, this host feeds httpapi.Deps.MasterHost: the /m/* master
#   console becomes reachable on it and the host is added to the CSRF
#   Origin/Referer allowlist. Leave unset (the default) to keep the
#   console disabled — the CSRF allowlist then falls back to the tenant
#   host alone. Provisioning DNS + a TLS cert for this host is a separate
#   operator action. The stg value is a CEO decision (proposal:
#   master.crm.crm.someu.com.br — confirm before enabling).
# MASTER_CONSOLE_HOST=
