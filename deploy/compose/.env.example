# Copy to deploy/compose/.env and fill in real values for local dev.
# Never commit .env. Same shape (filled by sops/secret manager) feeds stg in PR9.

# Postgres
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me

# Optional: explicit DSN for the app pool (SIN-62212). When unset, compose
# composes one from POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB. Override
# this in stg/prod to point at the app_runtime role (NOBYPASSRLS) — see
# docs/adr/0071-postgres-roles.md.
# DATABASE_URL=postgres://app_runtime:change-me@postgres:5432/crm?sslmode=disable

# MinIO
MINIO_ROOT_USER=crm-admin
MINIO_ROOT_PASSWORD=change-me-too

# Caddy security headers (SIN-62283 / ADR 0082 §1).
#   staging default: 300        (rollback < 5 min if a header breaks something)
#   production:      63072000   (Fase 1 onwards, after staging soak is clean)
HSTS_MAX_AGE=300

# Transactional email (SIN-62321 / ADR 0096).
#   Provider selection. Allowed values:
#     mailgun   — production (requires MAILGUN_* below)
#     recorder  — CI / integration tests (in-memory capture)
#     noop      — dev default; messages are validated and dropped
#   When APP_ENV=production, EMAIL_PROVIDER MUST be set or boot fails.
# EMAIL_PROVIDER=noop
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_REGION=us           # or: eu
